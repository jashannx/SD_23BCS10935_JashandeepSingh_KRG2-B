        <mxCell id="qSaCKScujajxPJi203jA-10" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;h2 data-start=&quot;757&quot; data-end=&quot;783&quot;&gt;📜 Meeting History APIs&lt;/h2&gt;&#xa;&lt;ol start=&quot;3&quot; data-start=&quot;785&quot; data-end=&quot;1038&quot;&gt;&#xa;&lt;li data-start=&quot;785&quot; data-end=&quot;1038&quot;&gt;&#xa;&lt;strong data-start=&quot;788&quot; data-end=&quot;814&quot;&gt;Add Meeting to History&lt;/strong&gt;&#xa;&lt;ul data-start=&quot;820&quot; data-end=&quot;1038&quot;&gt;&#xa;&lt;li data-start=&quot;820&quot; data-end=&quot;864&quot;&gt;&#xa;&lt;strong data-start=&quot;822&quot; data-end=&quot;830&quot;&gt;POST&lt;/strong&gt; &lt;code data-start=&quot;831&quot; data-end=&quot;862&quot;&gt;/api/v1/users/add_to_activity&lt;/code&gt;&#xa;&lt;/li&gt;&#xa;&lt;li data-start=&quot;868&quot; data-end=&quot;923&quot;&gt;&#xa;&lt;strong data-start=&quot;870&quot; data-end=&quot;886&quot;&gt;Description:&lt;/strong&gt; Store meeting code in user history&#xa;&lt;/li&gt;&#xa;&lt;li data-start=&quot;927&quot; data-end=&quot;1038&quot;&gt;&#xa;&lt;p data-start=&quot;929&quot; data-end=&quot;940&quot;&gt;&lt;strong data-start=&quot;929&quot; data-end=&quot;938&quot;&gt;Body:&lt;/strong&gt;&lt;/p&gt;&#xa;&lt;pre class=&quot;overflow-visible! px-0!&quot; data-start=&quot;946&quot; data-end=&quot;1038&quot;&gt;&lt;div class=&quot;relative w-full mt-4 mb-1&quot;&gt;&lt;div class=&quot;&quot;&gt;&lt;div class=&quot;relative&quot;&gt;&lt;div class=&quot;h-full min-h-0 min-w-0&quot;&gt;&lt;div class=&quot;h-full min-h-0 min-w-0&quot;&gt;&lt;div class=&quot;border border-token-border-light border-radius-3xl corner-superellipse/1.1 rounded-3xl&quot;&gt;&lt;div class=&quot;h-full w-full border-radius-3xl bg-token-bg-elevated-secondary corner-superellipse/1.1 overflow-clip rounded-3xl lxnfua_clipPathFallback&quot;&gt;&lt;div class=&quot;pointer-events-none absolute inset-x-4 top-12 bottom-4&quot;&gt;&lt;div class=&quot;pointer-events-none sti