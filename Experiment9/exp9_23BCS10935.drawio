  <diagram name="Page-1" id="2CujlwvLClJZ-wBQgyvT">
    <mxGraphModel dx="1075" dy="591" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="2Vs2_cClgsuASvimplDi-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;b&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;u&gt;1. Functional Requirements&lt;/u&gt;&lt;/font&gt;&lt;/b&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;User should be able to search events based on:&lt;span style=&quot;font-size: 14px;&quot;&gt;&lt;b&gt;&amp;nbsp;&lt;/b&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;title , location and date .&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;User should be able to view event details:&lt;/span&gt;Description,Metadata(cast, duration, language, ratings)Seat availability (available vs booked).&lt;/li&gt;&lt;li&gt;User should be able to:&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Select seats, Book tickets, Make payment.&lt;/span&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="90" width="520" x="190" y="100" as="geometry" />
        </mxCell>
        <mxCell id="2Vs2_cClgsuASvimplDi-2" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;b&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;u&gt;2. Non-Functional Requirements&lt;/u&gt;&lt;/font&gt;&lt;/b&gt;&lt;div&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/span&gt;&lt;div&gt;&lt;li data-section-id=&quot;fa5f9i&quot; data-start=&quot;690&quot; data-end=&quot;713&quot; style=&quot;&quot;&gt;&lt;strong data-start=&quot;692&quot; data-end=&quot;702&quot;&gt;Scale:&lt;/strong&gt; 100M DAU&lt;br&gt;&lt;/li&gt;&lt;li data-section-id=&quot;b2aye&quot; data-start=&quot;715&quot; data-end=&quot;805&quot; style=&quot;&quot;&gt;&lt;strong data-start=&quot;717&quot; data-end=&quot;733&quot;&gt;CAP Theorem:&amp;nbsp;&lt;/strong&gt;Search → High Availability (AP)|| Booking → High Consistency (CP)&lt;/li&gt;&lt;li data-section-id=&quot;b2aye&quot; data-start=&quot;715&quot; data-end=&quot;805&quot; style=&quot;&quot;&gt;&lt;strong data-start=&quot;809&quot; data-end=&quot;825&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Low Latency:&lt;/strong&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; Fast search &amp;amp; booking&lt;/span&gt;&lt;/li&gt;&lt;li data-section-id=&quot;1ym03l0&quot; data-start=&quot;851&quot; data-end=&quot;905&quot; style=&quot;&quot;&gt;&lt;strong data-start=&quot;853&quot; data-end=&quot;873&quot;&gt;Fault Tolerance:&lt;/strong&gt; System should handle failures&lt;/li&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="80" width="340" x="190" y="260" as="geometry" />
        </mxCell>
        <mxCell id="2Vs2_cClgsuASvimplDi-3" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;div style=&quot;text-align: left;&quot;&gt;&lt;b style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;u&gt;3. API Designing&lt;/u&gt;&lt;/font&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;&amp;nbsp;&lt;b&gt;Search Events:&lt;/b&gt;&amp;nbsp; &amp;nbsp; GET /v1/search?q={title}&amp;amp;location={city}&amp;amp;date={date}&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;→ List&amp;lt;EventId&amp;gt; (Pagination)&amp;nbsp;&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;&lt;b style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Event Details :&lt;/b&gt;GET /v1/event/{eventId}&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;→ Event Details + Seats[]&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;&amp;nbsp;&lt;b&gt;Seat Availability:&amp;nbsp;&lt;/b&gt;GET /v1/show/{showId}/seats&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;&lt;b&gt;Confirm Booking&lt;/b&gt;&amp;nbsp;:&amp;nbsp;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="80" width="500" x="190" y="410" as="geometry" />
        </mxCell>
        <mxCell id="2Vs2_cClgsuASvimplDi-4" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;div&gt;POST /v1/booking/confirm&lt;/div&gt;&lt;div&gt;{&lt;/div&gt;&lt;div&gt;&amp;nbsp; bookingId,&lt;/div&gt;&lt;div&gt;&amp;nbsp; paymentDetails&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;" vertex="1">
          <mxGeometry height="80" width="155" x="340" y="480" as="geometry" />
        </mxCell>
        <mxCell id="2Vs2_cClgsuASvimplDi-5" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;u&gt;&lt;b&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;4. Core Entities :&amp;nbsp;&lt;/font&gt;&lt;/b&gt;&lt;/u&gt;&lt;div&gt;&lt;ul data-start=&quot;1425&quot; data-end=&quot;1531&quot;&gt;&lt;li data-section-id=&quot;9vhf15&quot; data-start=&quot;1425&quot; data-end=&quot;1433&quot;&gt;User&lt;br&gt;&lt;/li&gt;&lt;li data-section-id=&quot;10m8ea8&quot; data-start=&quot;1434&quot; data-end=&quot;1461&quot;&gt;Event (Movie / Concert)&lt;br&gt;&lt;/li&gt;&lt;li data-section-id=&quot;1fbebbz&quot; data-start=&quot;1462&quot; data-end=&quot;1489&quot;&gt;Venue (Hall / Location)&lt;br&gt;&lt;/li&gt;&lt;li data-section-id=&quot;68z05n&quot; data-start=&quot;1490&quot; data-end=&quot;1498&quot;&gt;Show&lt;br&gt;&lt;/li&gt;&lt;li data-section-id=&quot;6cghhn&quot; data-start=&quot;1499&quot; data-end=&quot;1507&quot;&gt;Seat&lt;br&gt;&lt;/li&gt;&lt;li data-section-id=&quot;1166zxd&quot; data-start=&quot;1508&quot; data-end=&quot;1519&quot;&gt;Booking&lt;br&gt;&lt;/li&gt;&lt;li data-section-id=&quot;1wpvylu&quot; data-start=&quot;1520&quot; data-end=&quot;1531&quot;&gt;Payment&amp;nbsp;&lt;/li&gt;&lt;br&gt;&lt;/ul&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="100" width="270" x="110" y="600" as="geometry" />
        </mxCell>
        <mxCell id="2Vs2_cClgsuASvimplDi-7" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;div style=&quot;text-align: left;&quot;&gt;&lt;u style=&quot;&quot;&gt;&lt;b&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;5. Database Schema &lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;:&lt;/span&gt;&lt;/b&gt;&lt;/u&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;ul&gt;&lt;li style=&quot;text-align: left;&quot;&gt;User(user_id, name, email, phone)&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;Event(event_id, title, description, language, duration, rating)&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;Venue(venue_id, name, city, address)&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;Show(show_id, event_id, venue_id, start_time, end_time)&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;Seat(seat_id, venue_id, row, number)&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;Show_Seat(show_seat_id, show_id, seat_id, status)&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;→ status = AVAILABLE / LOCKED / BOOKED&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;Booking(booking_id, user_id, show_id, total_price, status)&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;Payment(payment_id, booking_id, amount, status)&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="250" width="500" x="110" y="750" as="geometry" />
        </mxCell>
